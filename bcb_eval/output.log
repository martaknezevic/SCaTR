import requests

from lxml import html

import pandas as pd

import sqlite3

def task_func(webpage_url: str, database_name: str = "my_database.db") -> int:
    # Fetch the HTML content
    if webpage_url.startswith("file://"):
        response = requests.get(webpage_url)
    else:
        response = requests.get(webpage_url)
    
    if response.status_code != 200:
        raise requests.RequestException(f"Failed to fetch {webpage_url}: {response.status_code}")
    
    # Parse the HTML
    tree = html.fromstring(response.content)
    
    # Find all tables
    tables = tree.findall(".//table")
    rows = []
    
    for table in tables:
        # Extract rows from the table
        trs = table.findall(".//tr")
        for tr in trs:
            cells = []
            for td in tr.findall(".//td"):
                cells.append(td.text_content().strip())
            rows.append(cells)
    
    # Check if there are any rows
    if not rows:
        return 0
    
    # Create DataFrame
    df = pd.DataFrame(rows)
    
    # Connect to the database
    try:
        conn = sqlite3.connect(database_name)
        cursor = conn.cursor()
        
        # Create table if it doesn't exist
        columns = df.columns.tolist()
        create_table_sql = f"CREATE TABLE IF NOT EXISTS my_table ({', '.join(columns)})" if columns else "CREATE TABLE IF NOT EXISTS my_table"
        cursor.execute(create_table_sql)
        
        # Insert data into the table
        df.to_sql('my_table', conn, if_exists='replace', index=False)
        conn.commit()
        conn.close()
        
        # Return the number of rows
        return len(rows)
    except sqlite3.DatabaseError as e:
        print(f"Database error: {e}")
        return 0
    except requests.RequestException as e:
        print(f"Network error: {e}")
        return 0

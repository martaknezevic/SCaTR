import requests

from lxml import html

import sqlite3

def task_func(webpage_url: str, database_name: str = "my_database.db") -> int:
    """
    This function parses HTML table data from a specified URL or local file and stores it into an SQLite database.
    The function handles different scenarios for fetching, processing, and storing data.

    Parameters:
    - webpage_url (str): The URL of the webpage or a local file path prefixed with "file://".
    - database_name (str): The name of the SQLite database file where the data is to be stored. Defaults to "my_database.db".

    Returns:
    - int: The number of rows in the parsed HTML table.

    Raises:
    - requests.RequestException: This exception is raised if there is a network issue in accessing the URL.
    - sqlite3.DatabaseError: This exception is raised in case of issues connecting to, or writing to, the SQLite database.
    """
    conn = sqlite3.connect(database_name)
    cur = conn.cursor()

    # Check if the table exists
    cur.execute("SELECT name FROM sqlite_master WHERE type = 'table' AND name = 'my_table'")
    if not cur.fetchone():
        # Create the table with the first table's headers
        tables = html.xpath('//table')
        if tables:
            first_table = tables[0]
            headers = [cell.text.strip() for cell in first_table.xpath('.//tr[1]/td') or first_table.xpath('.//tr[1]/th')]
            columns = ', '.join([f'{col} TEXT' for col in headers])
            cur.execute(f"CREATE TABLE my_table ({columns})")

    try:
        response = requests.get(webpage_url)
        response.raise_for_status()
    except requests.RequestException as e:
        print(f"Error fetching the webpage: {e}")
        conn.close()
        return 0

    html_content = response.text
    tables = html.xpath('//table')

    rows_inserted = 0

    for table in tables:
        # Extract headers
        headers = [cell.text.strip() for cell in table.xpath('.//tr[1]/td') or table.xpath('.//tr[1]/th')]
        # Extract data rows
        data_rows = []
        for row in table.xpath('.//tr'):
            cells = [cell.text.strip() for cell in row.xpath('.//td') or row.xpath('.//th')]
            data_rows.append(cells)

        # Insert data into the database
        for row in data_rows:
            # Create parameterized query
            values = tuple(row)
            cur.execute(
                "INSERT INTO my_table VALUES ({}),".format(
                    ", ".join(["?" for _ in row])
                )
            )
            cur.execute(
                "INSERT INTO my_table VALUES ({}),".format(
                    ", ".join(["?" for _ in row])
                ),
                values
            )
            rows_inserted += 1

    conn.commit()
    cur.close()
    conn.close()
    return rows_inserted

import matplotlib.pyplot as plt

import pandas as pd

import seaborn as sns

import numpy as np

def task_func(data_url="http://lib.stat.cmu.edu/datasets/boston", seed=42):
    """
    Draw the correlation heatmap of the Boston Housing dataset using Seaborn, with an option to save it to a specified file.

    Parameters:
        data_url (str, optional): URL to the dataset. Defaults to "http://lib.stat.cmu.edu/datasets/boston".
        seed (int, optional): Random seed for reproducibility. Defaults to 42.

    Returns:
        matplotlib.axes.Axes: The Axes object containing the heatmap plot.

    Raises:
        ValueError: If an error occurs in generating or saving the plot.

    Requirements:
        - matplotlib
        - os
        - pandas
        - seaborn
        - numpy
    """
    np.random.seed(seed)
    try:
        data = pd.read_csv(data_url)
    except Exception as e:
        raise ValueError(f"Error loading data: {e}")

    corr_matrix = data.corr()

    plt.figure(figsize=(10, 8))
    sns.heatmap(corr_matrix, annot=True, fmt=".2f", cmap='coolwarm', cbar=True, ax=plt.gca())

    plt.rcParams['font.family'] = 'Arial'
    plt.title('Correlation Heatmap of Boston Housing Dataset')
    plt.xlabel('Features')
    plt.ylabel('Features')

    # Save plot to file if a filename is provided
    if hasattr(data_url, 'filename'):
        filename = data_url.filename
    else:
        filename = None

    if filename is not None:
        plt.savefig(filename)
        plt.close()

    return plt.gca()

    # Plot the bar chart
    fig, ax = plt.subplots()
    ax.bar([word for word, _ in top_words], [count for _, count in top_words])
    ax.set_xlabel('Words')
    ax.set_ylabel('Frequency')
    ax.set_title('Top 10 Words')
    ax.tick_params(axis='x', rotation=45)
    
    return counter, ax

        # If encoding fails, raise ValueError
        raise ValueError("Unable to encode content") from None

    # Parse the reencoded content as JSON
    try:
        parsed_data = json.loads(reencoded_content)
    except json.JSONDecodeError:
        return {}

    return parsed_data

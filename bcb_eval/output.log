import requests

from lxml import html

import pandas as pd

import sqlite3

def task_func(webpage_url: str, database_name: str = "my_database.db") -> int:
    """
    Parses HTML table data from a specified URL or local file and stores it into an SQLite database.
    The function replaces the 'my_table' in the specified SQLite database with new data each time it is called.
    Returns the number of rows parsed and stored.

    Parameters:
    - webpage_url (str): The URL of the webpage or a local file path prefixed with "file://".
    - database_name (str): The name of the SQLite database file where the data is to be stored. Defaults to "my_database.db".

    Returns:
    - int: The number of rows in the parsed HTML table.

    Raises:
    - requests.RequestException: If there is a network issue in accessing the URL.
    - sqlite3.DatabaseError: If there is an issue connecting to or writing to the SQLite database.

    Notes:
    - The function replaces the 'my_table' in the database each time it is called.
    - If no table is found, returns 0.
    - The function uses 'requests' and 'lxml' for HTML parsing and 'sqlite3' for database operations.
    """

    # Step 1: Fetch the HTML content
    if webpage_url.startswith("file://"):
        response = requests.get(webpage_url)
    else:
        response = requests.get(webpage_url)
    
    if response.status_code != 200:
        raise requests.RequestException(f"Failed to fetch the webpage. Status code: {response.status_code}")
    
    html_content = response.text

    # Step 2: Parse the HTML content
    doc = html.fromstring(html_content)

    # Step 3: Find all tables in the HTML
    tables = doc.xpath("//table")

    # Step 4: Extract data from tables
    data = []
    for table in tables:
        rows = table.xpath(".//tr")
        for row in rows:
            cells = row.xpath(".//td | .//th")
            row_data = [cell.text_content().strip() for cell in cells]
            data.append(row_data)

    # Step 5: Convert data to DataFrame
    df = pd.DataFrame(data)

    # Step 6: Connect to SQLite database
    conn = sqlite3.connect(database_name)
    try:
        # Step 7: Drop the existing table if it exists
        cursor = conn.cursor()
        cursor.execute("DROP TABLE IF EXISTS my_table")
        
        # Step 8: Create the table with appropriate columns
        cursor.execute("""
            CREATE TABLE IF NOT EXISTS my_table (
                id INTEGER PRIMARY KEY,
                column1 TEXT,
                column2 TEXT
            )
        """)
        
        # Step 9: Insert data into the table
        df.to_sql("my_table", conn, if_exists="replace", index=False)
        
        # Step 10: Commit the transaction
        conn.commit()
        
        # Step 11: Return the number of rows
        return df.shape[0]
    
    except sqlite3.DatabaseError as e:
        # Handle database errors
        print(f"Database error: {e}")
        conn.rollback()
        return 0
    
    finally:
        # Step 12: Close the database connection
        conn.close()

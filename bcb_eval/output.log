import requests

from lxml import html

import sqlite3

def task_func(webpage_url: str, database_name: str = "my_database.db") -> int:
    """
    Parses HTML table data from a specified URL or local file and stores it into an SQLite database.
    The function handles different scenarios for fetching, processing, and storing data.

    Parameters:
    - webpage_url (str): The URL of the webpage or a local file path prefixed with "file://".
    - database_name (str): The name of the SQLite database file where the data is to be stored. Defaults to "my_database.db".

    Returns:
    - int: The number of rows in the parsed HTML table.

    Raises:
    - requests.RequestException: If there is a network issue in accessing the URL.
    - sqlite3.DatabaseError: If there is an error connecting to or writing to the SQLite database.

    Notes:
    - The function replaces the table "my_table" in the specified SQLite database each time it is called.
    - If the HTML content does not contain a table or if the table is empty, the function returns 0.
    - The function assumes that the table has columns defined by the headers of the HTML table.
    - The function uses the `requests` and `lxml` libraries for operations.
    """

    # Step 1: Fetch HTML content
    try:
        if webpage_url.startswith("file://"):
            response = requests.get(webpage_url)
        else:
            response = requests.get(webpage_url)
    except requests.RequestException as e:
        raise Exception(f"Network error: {e}")

    if response.status_code != 200:
        raise requests.RequestException(f"Failed to retrieve the webpage: {response.status_code}")

    # Step 2: Parse HTML content
    try:
        doc = html.fromstring(response.content)
    except Exception as e:
        raise Exception(f"Failed to parse HTML: {e}")

    # Step 3: Find the first table in the HTML
    tables = doc.xpath('//table')
    if not tables:
        return 0

    table = tables[0]

    # Step 4: Extract headers and data rows
    headers = []
    for cell in table.xpath('.//tr[1]/td | .//tr[1]/th'):
        headers.append(cell.text.strip())

    if not headers:
        return 0

    # Step 5: Prepare data rows
    data_rows = []
    for row in table.xpath('.//tr'):
        row_data = []
        for cell in row.xpath('.//td | .//th'):
            row_data.append(cell.text.strip())
        if row_data:
            data_rows.append(row_data)

    # Step 6: Connect to SQLite database
    try:
        conn = sqlite3.connect(database_name)
    except sqlite3.DatabaseError as e:
        raise Exception(f"Database error: {e}")

    # Step 7: Drop existing table if it exists
    cursor = conn.cursor()
    cursor.execute("DROP TABLE IF EXISTS my_table")

    # Step 8: Create the table with columns as headers
    columns = ', '.join([f'"{col}" TEXT' for col in headers])
    cursor.execute(f"CREATE TABLE my_table ({columns})")

    # Step 9: Insert headers and data rows
    cursor.execute("INSERT INTO my_table VALUES ({});".format(', '.join(['?'] * len(headers))))
    conn.commit()
    rows_inserted = 1

    for row in data_rows:
        cursor.execute("INSERT INTO my_table VALUES ({});".format(', '.join(['?'] * len(row))))
        conn.commit()
        rows_inserted += 1

    # Step 10: Close the connection
    conn.close()

    return rows_inserted

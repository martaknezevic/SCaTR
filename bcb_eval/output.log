import requests

import sqlite3

from lxml import html

def task_func(webpage_url: str, database_name: str = "my_database.db") -> int:
    """
    Parses HTML table data from a specified URL or local file and stores it into an SQLite database.
    The function replaces the table 'my_table' each time it is called.

    Parameters:
    - webpage_url (str): The URL of the webpage or a local file path prefixed with "file://".
    - database_name (str): The name of the SQLite database file where the data is to be stored. Defaults to "my_database.db".

    Returns:
    - int: The number of rows in the parsed HTML table.

    Raises:
    - requests.RequestException: If there is a network issue in accessing the URL.
    - sqlite3.DatabaseError: If there is an error connecting to or writing to the SQLite database.
    """
    try:
        # Fetch the HTML content from the URL or local file
        if webpage_url.startswith("file://"):
            response = requests.get(webpage_url, timeout=10)
        else:
            response = requests.get(webpage_url, timeout=10)
        
        if response.status_code != 200:
            raise requests.RequestException(f"HTTP error {response.status_code}")

        html_content = response.text

        # Parse the HTML content
        tree = html.fromstring(html_content)

        # Find all tables in the HTML
        tables = tree.findall('table')
        if not tables:
            return 0

        # Extract rows and cells from the tables
        rows = []
        for table in tables:
            for row in table.findall('tr'):
                cells = row.findall('td')
                if not cells:
                    continue
                row_data = [cell.text.strip() for cell in cells]
                rows.append(row_data)

        if not rows:
            return 0

        # Connect to the SQLite database
        conn = sqlite3.connect(database_name)
        cursor = conn.cursor()

        # Create table if it doesn't exist
        cursor.execute('CREATE TABLE IF NOT EXISTS my_table (value TEXT)')

        # Insert data into the table
        for row in rows:
            # Convert the row to a string for insertion
            cursor.execute('INSERT INTO my_table (value) VALUES (?)', (', '.join(row),))

        # Commit the transaction and close the connection
        conn.commit()
        conn.close()

        # Return the number of rows inserted
        return len(rows)

    except requests.RequestException as e:
        raise e
    except sqlite3.DatabaseError as e:
        raise e
    except Exception as e:
        raise e

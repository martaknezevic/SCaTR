import matplotlib.pyplot as plt

import pandas as pd

import seaborn as sns

import numpy as np

def task_func(data_url="http://lib.stat.cmu.edu/datasets/boston", seed=42):
    """
    Draw the correlation heatmap of the Boston Housing dataset using Seaborn, with an option to save it to a specified file.

    Parameters:
        data_url (str, optional): URL to load the Boston Housing dataset. Defaults to "http://lib.stat.cmu.edu/datasets/boston".
        seed (int, optional): Random seed for reproducibility. Defaults to 42.

    Returns:
        matplotlib.axes.Axes: The Axes object containing the heatmap plot.

    Raises:
        ValueError: If an error occurs in generating or saving the plot.

    Requirements:
        - matplotlib
        - os
        - pandas
        - seaborn
        - numpy
    """
    # Set random seed for reproducibility
    np.random.seed(seed)

    # Load the Boston dataset from the provided URL
    try:
        data = pd.read_csv(data_url)
    except Exception as e:
        raise ValueError(f"Error loading dataset: {e}")

    # Compute the correlation matrix
    corr = data.corr()

    # Create the heatmap
    plt.figure(figsize=(10, 8))
    sns.heatmap(
        corr,
        annot=True,
        fmt=".2f",
        cmap='coolwarm',
        center=corr.mean(),
        linewidths=0.5,
        linecolor='white',
        cbar_kws={"shrink": 0.5}
    )

    # Set the font to Arial, sans-serif
    plt.rcParams['font.family'] = 'sans-serif'
    plt.rcParams['font.sans-serif'] = ['Arial']

    # Save the plot to a file (default is 'correlation_heatmap.png')
    try:
        plt.savefig('correlation_heatmap.png')
    except Exception as e:
        raise ValueError(f"Error saving plot: {e}")

    # Return the Axes object
    return plt.gca()

import urllib.request

import re

from collections import Counter

import matplotlib.pyplot as plt

def task_func(url):
    """
    Downloads a text file from a specified URL, processes the text to count the frequency of each word,
    and then plots a bar chart showing the ten most frequently occurring words.

    Parameters:
    url (str): The URL from which the text file is to be downloaded. The URL should point directly to a text file.

    Returns:
    tuple: A tuple containing two elements:
        - Counter: A Counter object from the collections module, containing word frequencies in the text.
        - Axes: A matplotlib Axes object that represents the plotted bar chart of the ten most common words.
    """
    # Step 1: Download the text file from the URL
    response = urllib.request.urlopen(url)
    text = response.read().decode('utf-8')  # Decode the response to UTF-8

    # Step 2: Extract words using a regular expression
    # \b matches word boundaries, \w+ matches word characters
    words = re.findall(r'\b\w+\b', text)

    # Step 3: Count the frequency of each word
    word_counts = Counter(words)

    # Step 4: Get the top 10 most frequent words
    top_words = word_counts.most_common(10)

    # Step 5: Plot the top 10 words
    fig, ax = plt.subplots()
    ax.bar(*zip(*top_words))  # Unzip the list of (word, count) into two lists
    ax.set_xlabel('Words')
    ax.set_ylabel('Frequency')
    ax.set_title('Top 10 Words')
    ax.tick_params(axis='x', rotation=45)

    # Return the Counter and Axes object
    return word_counts, ax

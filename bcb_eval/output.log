        text = response.read().decode('utf-8')
    except Exception as e:
        raise RuntimeError(f"Failed to download the file: {e}")
    
    # Extract words using regex
    words = re.findall(r'\b\w+\b', text)
    counter = Counter(words)
    
    # Get the top 10 words

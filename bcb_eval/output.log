    Requirements:
        - matplotlib
        - os
        - pandas
        - seaborn
        - numpy
    """
    # Set random seed for reproducibility
    np.random.seed(seed)
    
    # Load the Boston dataset from the provided URL
    try:
        data = pd.read_csv(data_url)
    except Exception as e:
        raise ValueError(f"Failed to load data from {data_url}: {str(e)}")
    

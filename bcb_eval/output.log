import matplotlib.pyplot as plt

import seaborn as sns

import pandas as pd

import numpy as np

def task_func(data_url="http://lib.stat.cmu.edu/datasets/boston", seed=42, filename=None):
    """
    Draw the correlation heatmap of the Boston Housing dataset using Seaborn, with an option to save it to a specified file.

    Parameters:
        data_url (str, optional): URL to fetch the Boston Housing dataset from.
        seed (int, optional): Random seed for reproducibility. Defaults to 42.
        filename (str, optional): Filename to save the plot to. Defaults to None.

    Returns:
        matplotlib.axes.Axes: The Axes object containing the heatmap plot.

    Raises:
        ValueError: If an error occurs in generating or saving the plot.

    Requirements:
        - matplotlib
        - os
        - pandas
        - seaborn
        - numpy
    """
    np.random.seed(seed)
    data = pd.read_csv(data_url)

    # Set font family to Arial using sans-serif
    plt.rcParams['font.family'] = 'sans-serif'
    plt.rcParams['font.sans-serif'] = ['Arial']

    # Compute correlation matrix
    corr_matrix = data.corr()

    # Create the heatmap
    sns.heatmap(corr_matrix, annot=True, fmt=".2f", cmap='coolwarm', cbar=True)

    # Save the plot to the specified file if provided
    if filename:
        try:
            plt.savefig(filename)
        except Exception as e:
            raise ValueError(f"Error saving plot: {e}")

    # Return the Axes object
    return plt.gca()

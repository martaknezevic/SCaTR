    if from_encoding is None:
        # Use chardet to detect encoding
        try:
            encoding = chardet.detect(response.content)['encoding']
        except Exception as e:
            # If detection fails, raise ValueError
            raise ValueError("Unable to detect encoding for non-empty content") from e
    else:
        encoding = from_encoding

    # Decode the content
    try:
        decoded_content = response.content.decode(encoding)
    except UnicodeDecodeError:
        # If decoding fails, raise ValueError
        raise ValueError("Unable to decode content") from None

    # Re-encode to the target encoding
    try:

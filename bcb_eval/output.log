import requests

from lxml import html

import sqlite3

def task_func(webpage_url: str, database_name: str = "my_database.db") -> int:
    """
    Parses HTML table data from a specified URL or local file and stores it into an SQLite database.
    The function handles different scenarios for fetching, processing, and storing data.

    Parameters:
    - webpage_url (str): The URL of the webpage or a local file path prefixed with "file://".
    - database_name (str): The name of the SQLite database file where the data is to be stored. Defaults to "my_database.db".

    Returns:
    - int: The number of rows in the parsed HTML table.

    Raises:
    - requests.RequestException: This exception is raised if there is a network issue in accessing the URL.
    - sqlite3.DatabaseError: This exception is raised if there is an error connecting to or writing to the SQLite database.
    """

    # Check if the URL is a local file
    if webpage_url.startswith("file://"):
        # Open the local file
        with open(webpage_url[len("file://"):], "r") as f:
            html_content = f.read()
    else:
        # Fetch the HTML content
        try:
            response = requests.get(webpage_url)
            response.raise_for_status()
            html_content = response.text
        except requests.RequestException as e:
            raise sqlite3.DatabaseError("Error fetching HTML content") from e

    # Parse the HTML content
    try:
        parsed_html = html.fromstring(html_content)
    except Exception as e:
        raise sqlite3.DatabaseError("Error parsing HTML content") from e

    # Connect to the SQLite database
    conn = sqlite3.connect(database_name)
    cursor = conn.cursor()

    # Drop the table if it exists
    cursor.execute("DROP TABLE IF EXISTS my_table")

    # Find all tables
    tables = parsed_html.findall("table")
    if not tables:
        conn.close()
        return 0

    # Determine columns from the first table
    first_table = tables[0]
    trs = first_table.findall("tr")
    if not trs:
        conn.close()
        return 0

    first_tr = trs[0]
    tds = first_tr.findall("td")
    if not tds:
        conn.close()
        return 0

    columns = [td.text_content() for td in tds]

    # Create the table
    create_table_sql = ", ".join(["{} TEXT".format(col) for col in columns])
    cursor.execute("CREATE TABLE IF NOT EXISTS my_table ({})".format(create_table_sql))

    # Insert all data from all tables
    row_count = 0
    for table in tables:
        trs = table.findall("tr")
        if not trs:
            continue
        for tr in trs:
            row = [td.text_content() for td in tr.findall("td")]
            placeholders = ", ".join(["?"] * len(columns))
            cursor.execute("INSERT INTO my_table VALUES ({})".format(placeholders), row)
            row_count += 1

    # Commit the transaction
    conn.commit()

    # Close the connection
    conn.close()

    return row_count

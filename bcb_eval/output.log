import requests

from lxml import html

import pandas as pd

import sqlite3

def task_func(webpage_url: str, database_name: str = "my_database.db") -> int:
    """
    Parses HTML table data from a specified URL or local file and stores it into an SQLite database.
    The function replaces the table 'my_table' in the specified SQLite database each time it is called.

    Parameters:
    - webpage_url (str): The URL of the webpage or a local file path prefixed with "file://".
    - database_name (str): The name of the SQLite database file where the data is to be stored. Defaults to "my_database.db".

    Returns:
    - int: The number of rows in the parsed HTML table.

    Raises:
    - requests.RequestException: If there is a network issue in accessing the URL.
    - sqlite3.DatabaseError: If there is an issue connecting to or writing to the SQLite database.
    """
    # Check if the URL is a local file (starts with 'file://')
    if webpage_url.startswith('file://'):
        html_content = html.fromstring(requests.get(webpage_url[7:]).content)
    else:
        html_content = html.fromstring(requests.get(webpage_url).content)
    
    # Find all tables in the HTML
    tables = html_content.findall('table')
    if not tables:
        return 0
    
    # Extract data from all tables
    data = []
    for table in tables:
        rows = []
        for tr in table.findall('tr'):
            row = []
            for td in tr.findall('td'):
                row.append(td.text_content())
            rows.append(row)
        data.append(rows)
    
    # Check if data is empty
    if not data:
        return 0
    
    # Create DataFrame from the extracted data
    if not data[0]:
        return 0
    
    columns = data[0]
    df = pd.DataFrame(data, columns=columns)
    
    # Connect to the SQLite database
    conn = sqlite3.connect(database_name)
    cursor = conn.cursor()
    
    # Create table if it doesn't exist
    cursor.execute('CREATE TABLE IF NOT EXISTS my_table (id INTEGER PRIMARY KEY, ' + ', '.join(columns) + ')')
    
    # Insert data into the database
    df.to_sql('my_table', conn, if_exists='replace', index=False)
    
    # Commit changes and close connection
    conn.commit()
    conn.close()
    
    # Return the number of rows
    return len(df.index)

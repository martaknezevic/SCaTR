import requests

from pathlib import Path

import zipfile

import os

def task_func(url, filename):
    """
    Downloads and extracts a zip file from a specified URL.

    Parameters:
    url (str): The URL of the zip file to download.
    filename (str): The filename under which the downloaded zip file will be saved.

    Returns:
    tuple: A tuple containing a status message and a list of filenames in the unzipped directory, or an empty list if extraction fails.

    Note:
    the status message will contain "Error" when:
    - Network-related exceptions are raised if the download fails.
    - File-related exceptions are raised if there is an issue with file handling or extraction.

    Requirements:
    - requests
    - pathlib.Path
    - zipfile
    """
    # Define the paths for the download and unzipped directories
    download_dir = DOWNLOAD_DIR / filename
    zip_dir = ZIP_DIR

    # Create the directories if they don't exist
    if not download_dir.exists():
        os.makedirs(download_dir)
    if not zip_dir.exists():
        os.makedirs(zip_dir)

    # Attempt to download the zip file
    try:
        response = requests.get(url, stream=True)
        if response.status_code != 200:
            return ("Error", [])
        # Write the file to disk
        with open(download_dir / filename, 'wb') as f:
            for chunk in response.iter_content(chunk_size=1024):
                if chunk:
                    f.write(chunk)
    except requests.exceptions.RequestException as e:
        return ("Error", [])
    except Exception as e:
        return ("Error", [])

    # Attempt to extract the zip file
    try:
        with zipfile.ZipFile(download_dir / filename, 'r') as zip_ref:
            zip_ref.extractall(zip_dir)
    except zipfile.ZipFileError as e:
        return ("Error", [])
    except Exception as e:
        return ("Error", [])

    # Collect all files in the unzipped directory
    filenames = [f for f in os.listdir(zip_dir) if os.path.isfile(os.path.join(zip_dir, f))]
    return ("Download and extraction successful", filenames)

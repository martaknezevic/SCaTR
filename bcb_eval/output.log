import requests

from lxml import html

import sqlite3

def task_func(webpage_url: str, database_name: str = "my_database.db") -> int:
    """
    Parses HTML table data from a specified URL or local file and stores it into an SQLite database.
    The function replaces the 'my_table' table each time it is called.

    Parameters:
    - webpage_url (str): The URL of the webpage or a local file path prefixed with "file://".
    - database_name (str): The name of the SQLite database file. Defaults to "my_database.db".

    Returns:
    - int: The number of rows inserted into the database.

    Raises:
    - requests.RequestException: If there is a network error.
    - sqlite3.DatabaseError: If there is a database error.
    """
    # Handle local file paths
    if webpage_url.startswith("file://"):
        file_path = webpage_url[7:]
        response = requests.get(file_path)
        if response.status_code != 200:
            raise requests.RequestException(f"Failed to fetch local file: {file_path}")
        html_content = response.text
    else:
        # Handle web URLs
        response = requests.get(webpage_url)
        if response.status_code != 200:
            raise requests.RequestException(f"Failed to fetch web page: {webpage_url}")
        html_content = response.text

    # Parse the HTML content
    try:
        tree = html.fromstring(html_content)
    except Exception as e:
        raise requests.RequestException(f"Failed to parse HTML: {e}")

    # Find the first table in the HTML
    tables = tree.xpath('//table')
    if not tables:
        return 0

    first_table = tables[0]
    first_row = first_table.xpath('.//tr[1]')[0]  # First row is assumed to be the header

    # Extract headers from the first row
    headers = []
    for cell in first_row.xpath('.//td|..//th'):
        headers.append(cell.text.strip())

    # Extract data rows
    data_rows = []
    for row in first_table.xpath('.//tr'):
        if row == first_row:
            continue  # Skip the header row
        data_row = []
        for cell in row.xpath('.//td|..//th'):
            data_row.append(cell.text.strip())
        data_rows.append(data_row)

    # Check if no data rows were found
    if not data_rows:
        return 0

    # Connect to the SQLite database
    conn = sqlite3.connect(database_name)
    cursor = conn.cursor()

    # Create table if it does not exist
    columns = ', '.join(headers)
    cursor.execute(f'CREATE TABLE IF NOT EXISTS my_table ({columns})')

    # Insert data rows
    for row in data_rows:
        # Use parameterized query to avoid SQL injection
        cursor.execute('INSERT INTO my_table VALUES (' + ','.join(['?'] * len(row)) + ')', row)
        conn.commit()

    # Close the connection
    conn.close()

    # Return the number of rows inserted
    return len(data_rows)

    corr = data.corr()
    
    # Create the heatmap
    fig, ax = plt.subplots()
    sns.heatmap(corr, annot=True, cmap='coolwarm', fmt=".2f", ax=ax)
    
    # Set the font family to Arial and sans-serif
    sns.set(font='Arial', font_family='sans-serif')
    
    # Return the Axes object
    return ax

import requests

from lxml import html

import sqlite3

def task_func(webpage_url: str, database_name: str = "my_database.db") -> int:
    """
    Parses HTML table data from a specified URL or local file and stores it into an SQLite database.
    Replaces the 'my_table' in the specified SQLite database each time it is called.

    Parameters:
    - webpage_url (str): The URL of the webpage or a local file path prefixed with "file://".
    - database_name (str): The name of the SQLite database file where the data is to be stored. Defaults to "my_database.db".

    Returns:
    - int: The number of rows in the parsed HTML table.

    Raises:
    - requests.RequestException: If there is a network issue in accessing the URL.
    - sqlite3.DatabaseError: If there is an issue connecting to or writing to the SQLite database.

    Notes:
    - The function replaces the 'my_table' in the specified SQLite database each time it is called.
    - If the HTML content does not contain a table or if the table is empty, the function returns 0.
    - The function uses the 'requests', 'lxml', 'pandas', and 'sqlite3' libraries for its operations.
    """

    # Handle local file paths
    if webpage_url.startswith("file://"):
        with open(webpage_url, 'r') as f:
            content = f.read()
    else:
        # Fetch the webpage content
        response = requests.get(webpage_url)
        if response.status_code != 200:
            raise requests.RequestException(f"Failed to fetch the webpage: {response.status_code}")
        content = response.text

    # Parse the HTML content
    try:
        html_content = html.fromstring(content)
    except Exception as e:
        raise requests.RequestException(f"Failed to parse HTML: {e}")

    # Find the first table in the HTML
    tables = html_content.xpath('//table')
    if not tables:
        return 0

    table = tables[0]

    # Extract headers and data rows
    rows = table.xpath('.//tr')
    if not rows:
        return 0
    first_row = rows[0]
    cells = first_row.xpath('.//td')
    if not cells:
        return 0
    headers = [cell.text_content() for cell in cells]

    data_rows = []
    for row in rows[1:]:
        cells = row.xpath('.//td')
        if not cells:
            continue
        data_rows.append([cell.text_content() for cell in cells])

    # Create SQLite database connection
    conn = sqlite3.connect(database_name)
    cursor = conn.cursor()

    # Create table if it doesn't exist
    create_table_sql = f"CREATE TABLE IF NOT EXISTS my_table ({', '.join([f'{col} TEXT' for col in headers])})"
    cursor.execute(create_table_sql)

    # Insert data into the table
    insert_sql = "INSERT INTO my_table VALUES (" + ",".join(["?" for _ in headers]) + ")"
    cursor.executemany(insert_sql, [tuple(row) for row in data_rows])

    # Commit the transaction
    conn.commit()

    # Close the connection
    conn.close()

    # Return the number of rows inserted
    return len(data_rows)

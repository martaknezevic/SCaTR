import requests

from lxml import html

import pandas as pd

import sqlite3

def task_func(webpage_url: str, database_name: str = "my_database.db") -> int:
    """
    Parses HTML table data from a specified URL or local file and stores it into an SQLite database.
    Replaces the 'my_table' in the database each time the function is called.

    Parameters:
    - webpage_url (str): The URL of the webpage or a local file path prefixed with "file://".
    - database_name (str): The name of the SQLite database file where the data is to be stored.
      Defaults to "my_database.db".

    Returns:
    - int: The number of rows in the parsed HTML table.

    Raises:
    - requests.RequestException: If there is a network issue in accessing the URL.
    - sqlite3.DatabaseError: If there is a problem connecting to or writing to the SQLite database.
    """

    # Handle local file paths
    if webpage_url.startswith("file://"):
        url = webpage_url[7:]
    else:
        url = webpage_url

    # Fetch the HTML content
    try:
        response = requests.get(url)
        response.raise_for_status()
    except requests.RequestException as e:
        raise e

    # Parse the HTML content
    try:
        tree = html.fromstring(response.content)
    except Exception as e:
        raise e

    # Find all tables in the HTML
    tables = tree.xpath('//table')
    if not tables:
        return 0

    # Read the first table into a DataFrame
    html_content = response.content
    df = pd.read_html(html_content)[0]

    # Connect to the SQLite database
    try:
        conn = sqlite3.connect(database_name)
    except sqlite3.DatabaseError as e:
        raise e

    # Insert the DataFrame into the SQLite table
    df.to_sql('my_table', conn, if_exists='replace', index=False)

    # Close the connection
    conn.close()

    # Return the number of rows
    return len(df)

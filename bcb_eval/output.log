    try:
        response = requests.get(url)
        response.raise_for_status()  # Raises HTTPError for bad responses
    except requests.exceptions.RequestException as e:
        return f"Error: Unable to download the file from the provided URL."

    # Step 2: Check content type
    if response.headers['Content-Type'] != 'application/zip':
        return "Error: The URL does not point to a ZIP file."

    # Step 3: Save the file
    filename = os.path.splitext(os.path.basename(url))[0]
    download_path_full = os.path.join(download_path, filename)
    os.makedirs(os.path.dirname(download_path_full), exist_ok=True)
    with open(download_path_full, 'wb') as f:
        f.write(response.content)

    # Step 4: Try to extract the ZIP
    try:
        with ZipFile(download_path_full, 'r') as zip_ref:
            zip_ref.extractall(download_path_full)
    except BadZipFile:
        return "Error: The downloaded file is not a valid ZIP file."
    except Exception as e:
        return f"Error: {str(e)}"

    # Step 5: Return the path to the directory
    return download_path_full

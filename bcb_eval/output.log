import requests

from lxml import html

import sqlite3

def task_func(webpage_url: str, database_name: str = "my_database.db") -> int:
    """
    Parses HTML table data from a specified URL or local file and stores it into an SQLite database.
    The function replaces the 'my_table' table each time it is called.

    Parameters:
    - webpage_url (str): The URL of the webpage or a local file path prefixed with "file://".
    - database_name (str): The name of the SQLite database file where the data is to be stored. Defaults to "my_database.db".

    Returns:
    - int: The number of rows in the parsed HTML table.

    Raises:
    - sqlite3.DatabaseError: If there's an error connecting to or writing to the SQLite database.
    - requests.RequestException: If there's a network error in accessing the URL.
    """

    # Handle local file paths
    if webpage_url.startswith("file://"):
        local_path = webpage_url[7:]  # Remove "file://"
        try:
            with open(local_path, 'r', encoding='utf-8') as f:
                html_content = f.read()
        except Exception as e:
            raise sqlite3.DatabaseError(f"Failed to open local file: {e}")
    else:
        # Handle URL
        try:
            response = requests.get(webpage_url)
            response.raise_for_status()
            html_content = response.text
        except requests.RequestException as e:
            raise sqlite3.DatabaseError(f"Network error: {e}")

    # Parse the HTML content
    try:
        parsed_html = html.fromstring(html_content)
    except Exception as e:
        raise sqlite3.DatabaseError(f"Failed to parse HTML: {e}")

    # Find all tables in the HTML
    tables = parsed_html.xpath('//table')
    if not tables:
        return 0

    # Check if any table has rows
    first_table = tables[0]
    rows = first_table.xpath('.//tr')
    if not rows:
        return 0

    # Check if first row has cells
    first_row = rows[0]
    cells = first_row.xpath('.//td')
    if not cells:
        return 0

    # Determine number of columns
    num_columns = len(cells)

    # Connect to the SQLite database
    conn = sqlite3.connect(database_name)
    cursor = conn.cursor()

    # Create table if it doesn't exist
    create_table_sql = f'CREATE TABLE IF NOT EXISTS my_table (id INTEGER PRIMARY KEY, {", ".join([f"col_{i}" for i in range(num_columns)])})'
    cursor.execute(create_table_sql)
    conn.commit()

    # Extract data rows
    data_rows = []
    for row in rows:
        cells = row.xpath('.//td')
        if not cells:
            continue
        data_row = [cell.text_content() for cell in cells]
        data_rows.append(data_row)

    # Insert data into the table
    for data_row in data_rows:
        insert_sql = f'INSERT INTO my_table ({", ".join([f"col_{i}" for i in range(num_columns)])}) VALUES ({", ".join(["?"] * num_columns)})'
        cursor.execute(insert_sql, data_row)
        conn.commit()

    # Get the count of rows
    cursor.execute('SELECT COUNT(*) FROM my_table')
    count = cursor.fetchone()[0]

    # Close the connection
    conn.close()

    return count
